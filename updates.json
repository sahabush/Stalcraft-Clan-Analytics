---
---
{%- assign html = site.static_files | where_exp:"f","f.extname == '.html'" -%}
{%- assign devlogs = html | where_exp:"f","f.name contains 'devlog'" -%}
{%- assign patches = html | where_exp:"f","f.name contains 'patch'" -%}
{%- assign logs = devlogs | concat: patches -%}
[
{%- for f in logs -%}
{"file":{{ f.name | jsonify }},"path":{{ f.path | jsonify }},"modified":"{{ f.modified_time | date_to_xmlschema }}"}{%- unless forloop.last -%},{%- endunless -%}
{%- endfor -%}
]
